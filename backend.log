                  WHERE NOT (m1."IsDelete") AND (@ef_filter__p2 OR m1."ComId" = @ef_filter__CurrentComId OR m1."ComId" IS NULL)
              ) AS m2 ON i1."MobileDeviceId" = m2."Id"
              WHERE NOT (i1."IsDelete") AND (@ef_filter__p2 OR i1."ComId" = @ef_filter__CurrentComId OR i1."ComId" IS NULL) AND NOT (i1."IsSold") AND (i."MobileDeviceId" = i1."MobileDeviceId" OR (i."MobileDeviceId" IS NULL AND i1."MobileDeviceId" IS NULL)) AND (i."ProductId" = i1."ProductId" OR (i."ProductId" IS NULL AND i1."ProductId" IS NULL))
              LIMIT 1)
          WHEN (
              SELECT p0."Id"
              FROM "Inventory" AS i2
              LEFT JOIN (
                  SELECT p."Id"
                  FROM "Products" AS p
                  WHERE NOT (p."IsDelete") AND (@ef_filter__p2 OR p."ComId" = @ef_filter__CurrentComId OR p."ComId" IS NULL)
              ) AS p0 ON i2."ProductId" = p0."Id"
              WHERE NOT (i2."IsDelete") AND (@ef_filter__p2 OR i2."ComId" = @ef_filter__CurrentComId OR i2."ComId" IS NULL) AND NOT (i2."IsSold") AND (i."MobileDeviceId" = i2."MobileDeviceId" OR (i."MobileDeviceId" IS NULL AND i2."MobileDeviceId" IS NULL)) AND (i."ProductId" = i2."ProductId" OR (i."ProductId" IS NULL AND i2."ProductId" IS NULL))
              LIMIT 1) IS NOT NULL THEN (
